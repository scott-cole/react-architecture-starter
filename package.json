    "@storybook/addon-essentials": "^8.0.8",
    "@storybook/addon-interactions": "^8.0.8",
    "@storybook/addon-links": "^8.0.8",
    "@storybook/blocks": "^8.0.8",
    "@storybook/testing-library": "^0.2.2",
    "storybook": "^8.0.8",
    "@storybook/test": "^8.0.8",
